<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="<%= settings.logo %>">
    <title>Pocketeer Blog - Trends & Tips</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="top-navbar">
        <div class="nav-content">
            <div class="nav-left">
                <a href="/" style="color:var(--text-main); font-size:1.5em; margin-right: 15px;"><i class="fas fa-arrow-left"></i></a>
                <a href="/"><img src="<%= settings.logo %>" alt="Pocketeer Logo" class="nav-logo"></a>
            </div>
            <div class="nav-right">
                <a href="/blog" style="color:var(--text-main); font-size:1.1em; font-weight:600; text-decoration:none; margin-right:20px;">Blog</a>
                <button class="theme-toggle" id="theme-toggle"><i class="fas fa-moon"></i></button>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <h1 style="text-align: center; margin-bottom: 40px;">The Aesthetic Edit</h1>
        <div class="blog-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
            <% blogs.forEach(post => { %>
                <div class="product-card" style="animation: fadeUp 0.6s ease-out;">
                    <a href="/blog/<%= post.id %>" class="card-link-wrapper">
                        <img src="<%= post.image %>" alt="<%= post.title %>" style="width:100%; height:200px; object-fit:cover;">
                        <div class="product-info">
                            <h3 class="product-title" style="margin-bottom: 10px;"><%= post.title %></h3>
                            <p style="color:var(--text-muted); font-size:0.9em; margin-bottom:10px;"><%= post.date %></p>
                            <p><%= post.excerpt %></p>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </main>
    
    <!-- Footer with Marquee (To be added via another step) -->
    <%- include('footer.ejs', {reviews: reviews, settings: settings}) %> <!-- Let me create a footer partial to make this clean! -->
    
    <script src="/script.js"></script>
</body>
</html>
