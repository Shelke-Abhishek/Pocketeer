<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="<%= settings.logo %>">
    <title>Admin Login - Pocketeer</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .login-container { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; text-align: center; padding: 20px; }
        .login-box { background: var(--card-bg); padding: 50px; border-radius: 20px; box-shadow: var(--shadow); max-width: 400px; width: 100%; animation: fadeUp 0.6s ease-out; }
        .login-box h1 { margin-bottom: 20px; }
        .login-box input { width: 100%; padding: 15px; margin-bottom: 15px; border: 1px solid var(--border-color); border-radius: 8px; font-family: inherit; box-sizing: border-box; background: var(--primary-bg); color: var(--text-main); }
        .submit-btn { width: 100%; background: var(--accent); color: white; border: none; padding: 15px; border-radius: 30px; font-weight: bold; cursor: pointer; transition: transform 0.1s, opacity 0.2s; }
        .submit-btn:active { transform: scale(0.98); }
        .error { color: #e74c3c; margin-bottom: 15px; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-box">
            <img src="<%= settings.logo %>" alt="Logo" style="height: 40px; margin-bottom: 20px;">
            <h1>Admin Access</h1>
            <% if(error) { %> <div class="error"><%= error %></div> <% } %>
            <form action="/login" method="POST">
                <input type="text" name="username" placeholder="Username" required>
                <input type="password" name="password" placeholder="Password" required>
                <button type="submit" class="submit-btn">Login to Dashboard</button>
            </form>
            <a href="/" style="display: block; margin-top: 20px; color: var(--text-muted); text-decoration: none;">&larr; Back to Store</a>
        </div>
    </div>
</body>
</html>
