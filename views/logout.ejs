<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="<%= settings.logo %>">
    <title>Logged Out - Pocketeer</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .logout-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            text-align: center;
            padding: 20px;
        }
        .logout-box {
            background: var(--card-bg);
            padding: 50px;
            border-radius: 20px;
            box-shadow: var(--shadow);
            max-width: 500px;
            animation: fadeUp 0.6s ease-out;
        }
        .logout-box h1 {
            color: var(--text-main);
            margin-bottom: 15px;
        }
        .logout-box p {
            color: var(--text-muted);
            margin-bottom: 30px;
        }
        .return-btn {
            background: var(--accent);
            color: white;
            text-decoration: none;
            padding: 15px 30px;
            border-radius: 30px;
            font-weight: 600;
            transition: opacity 0.2s;
        }
        .return-btn:hover {
            opacity: 0.9;
        }
    </style>
    <script>
        (function() {
            var currentTheme = localStorage.getItem("theme");
            var prefersDarkScheme = window.matchMedia("(prefers-color-scheme: dark)");
            if (currentTheme === "dark" || (!currentTheme && prefersDarkScheme.matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <div class="logout-container">
        <div class="logout-box">
            <img src="<%= settings.logo %>" alt="Logo" style="height: 50px; margin-bottom: 20px;">
            <h1>Logged Out Successfully</h1>
            <p>Your secure admin session has been terminated. You are being redirected to the storefront...</p>
            <a href="/" class="return-btn">Return to Storefront Now</a>
        </div>
    </div>
    <script>
        // Force browser to drop basic auth cache
        document.execCommand("ClearAuthenticationCache");
        setTimeout(() => window.location.href = '/', 3000);
    </script>
</body>
</html>
